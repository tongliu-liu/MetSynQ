# ==========================================
# 1. Mass Spectrometry Raw Data & Large Files
# (Crucial to prevent GitHub from rejecting the push due to size limits)
# ==========================================
*.wiff
*.wiff.scan
*.mzML
*.cdf
*.raw
*.d

# ==========================================
# 2. MetSynQ Auto-generated Outputs & Caches
# ==========================================
temp/
picture/
runs/                # YOLO auto-generated runs folder during inference/training
*.pkl                # Ignore large serialized files like dataset_all_samples.pkl
xcms_peak_list.csv   # Temporary file generated by the R script

# ==========================================
# 3. Deep Learning Model Weights
# ==========================================
# GitHub free tier limits single files to 100MB.
# Keep the line below commented out ONLY if your best.pt is < 100MB and you want to push it.
# If it's > 100MB, uncomment the line below and use Zenodo or cloud drives for weights.
# weights/*.pt
# *.pt

# ==========================================
# 4. Python Caches & Virtual Environments
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
.venv/
miniconda3/
anaconda3/

# ==========================================
# 5. OS & IDE Hidden Files
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
.ipynb_checkpoints/